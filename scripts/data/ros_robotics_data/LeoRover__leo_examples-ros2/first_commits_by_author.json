          "patch": "@@ -0,0 +1,27 @@\n+name: CI\n+\n+on:\n+  workflow_dispatch:\n+  push:\n+    branches:\n+      - main\n+  pull_request:\n+    branches:\n+      - main\n+\n+jobs:\n+  industrial_ci:\n+    runs-on: ubuntu-24.04\n+    strategy:\n+      fail-fast: false\n+      matrix:\n+        ROS_DISTRO: [jazzy, kilted, rolling]\n+        ROS_REPO: [testing, main]\n+    env:\n+      ROS_DISTRO: ${{ matrix.ROS_DISTRO }}\n+      ROS_REPO: ${{ matrix.ROS_REPO }}\n+    steps:\n+      - name: Checkout repo\n+        uses: actions/checkout@v4\n+      - name: Source tests\n+        uses: \"ros-industrial/industrial_ci@master\""
