      "date": "2020-03-12T00:18:30Z",
      "sha": "3d777ed384e181c151e20111769c5851a4fc234d",
      "message": "Another fix for finding Python on cmake>=3.12\n\nThe variables set by FindPythonX all begin with PythonX_.",
      "files_changed": 1,
      "additions": 1,
      "deletions": 0,
      "commit_type": "docs",
      "files": [
        {
          "sha": "bd600b6682d5f2d9918df1e27470e4140d0c8f12",
          "filename": "patch/CMakeLists.txt",
          "status": "modified",
          "additions": 1,
          "deletions": 0,
          "changes": 1,
          "blob_url": "https://github.com/mavlink/mavlink-gbp-release/blob/3d777ed384e181c151e20111769c5851a4fc234d/patch%2FCMakeLists.txt",
          "raw_url": "https://github.com/mavlink/mavlink-gbp-release/raw/3d777ed384e181c151e20111769c5851a4fc234d/patch%2FCMakeLists.txt",
          "contents_url": "https://api.github.com/repos/mavlink/mavlink-gbp-release/contents/patch%2FCMakeLists.txt?ref=3d777ed384e181c151e20111769c5851a4fc234d",
          "patch": "@@ -26,6 +26,7 @@ endif()\n \n if (NOT CMAKE_VERSION VERSION_LESS \"3.12\")\n     find_package(Python${Py_VERSION} COMPONENTS Interpreter)\n+    set(Python_EXECUTABLE \"${Python${Py_VERSION}_EXECUTABLE}\")\n else()\n     # find libraries with cmake modules\n     find_package(PythonInterp ${Py_VERSION} REQUIRED)"
        }
      ]
