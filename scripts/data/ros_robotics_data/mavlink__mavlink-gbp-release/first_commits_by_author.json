    {
      "author": "sloretz",
      "date": "2018-06-19T22:45:41Z",
      "sha": "f0c94d2f82728bf53a0a2eacf4c498eab4fc5679",
      "message": "Fail if user calls find_package() with wrong case\n\nGenerated include directories are correct only if user calls\nfind_package() with lowercase `mavlink`. This commit makes the config\nfile fail if the user uses a different case.",
      "files_changed": 1,
      "additions": 10,
      "deletions": 0,
      "commit_type": "other",
      "files": [
        {
          "sha": "f4da8ebf10bbab9137ae98ea643435a793acb183",
          "filename": "patch/config.cmake.in",
          "status": "modified",
          "additions": 10,
          "deletions": 0,
          "changes": 10,
          "blob_url": "https://github.com/mavlink/mavlink-gbp-release/blob/f0c94d2f82728bf53a0a2eacf4c498eab4fc5679/patch%2Fconfig.cmake.in",
          "raw_url": "https://github.com/mavlink/mavlink-gbp-release/raw/f0c94d2f82728bf53a0a2eacf4c498eab4fc5679/patch%2Fconfig.cmake.in",
          "contents_url": "https://api.github.com/repos/mavlink/mavlink-gbp-release/contents/patch%2Fconfig.cmake.in?ref=f0c94d2f82728bf53a0a2eacf4c498eab4fc5679",
          "patch": "@@ -1,3 +1,13 @@\n+# Force case-sensitive search\n+string(COMPARE EQUAL \"@PKG_NAME@\" \"${CMAKE_FIND_PACKAGE_NAME}\" case_sensitive_match)\n+if (NOT case_sensitive_match)\n+  if (NOT ${CMAKE_FIND_PACKAGE_NAME}_FIND_QUIETLY)\n+    message(AUTHOR_WARNING \"got '${CMAKE_FIND_PACKAGE_NAME}', use case-sensitive find_package(@PKG_NAME@) instead\")\n+  endif()\n+  set(${CMAKE_FIND_PACKAGE_NAME}_FOUND false)\n+  return()\n+endif()\n+\n if (@PKG_NAME@_CONFIG_INCLUDED)\n   return()\n endif()"
        }
      ]
    },
    {
      "author": "guludo",
      "date": "2016-11-16T16:19:24Z",
      "sha": "402c5800b91b11d4b87bfd0bc4ecf09106a15995",
      "message": "Fix @PKG_NAME@_INCLUDE_DIR variable\n\nThe previous approach hardcoded the path to the include directory and cross\ncompilation using a sysroot directory would fail. This patch takes the\nresulting config files generated from other ROS packages as reference.",
      "files_changed": 1,
      "additions": 2,
      "deletions": 1,
      "commit_type": "other",
      "files": [
        {
          "sha": "34bed613973868ad3c87d6976388b490d95af788",
          "filename": "patch/config.cmake.in",
          "status": "modified",
          "additions": 2,
          "deletions": 1,
          "changes": 3,
          "blob_url": "https://github.com/mavlink/mavlink-gbp-release/blob/402c5800b91b11d4b87bfd0bc4ecf09106a15995/patch%2Fconfig.cmake.in",
          "raw_url": "https://github.com/mavlink/mavlink-gbp-release/raw/402c5800b91b11d4b87bfd0bc4ecf09106a15995/patch%2Fconfig.cmake.in",
          "contents_url": "https://api.github.com/repos/mavlink/mavlink-gbp-release/contents/patch%2Fconfig.cmake.in?ref=402c5800b91b11d4b87bfd0bc4ecf09106a15995",
          "patch": "@@ -3,7 +3,8 @@ if (@PKG_NAME@_CONFIG_INCLUDED)\n endif()\n set(@PKG_NAME@_CONFIG_INCLUDED TRUE)\n \n-set(@PKG_NAME@_INCLUDE_DIRS \"@CMAKE_INSTALL_PREFIX@/include\")\n+get_filename_component(include \"${@PKG_NAME@_DIR}/../../../include\" ABSOLUTE)\n+set(@PKG_NAME@_INCLUDE_DIRS ${include})\n set(@PKG_NAME@_DIALECTS @PKG_MAVLINK_DIALECTS@)\n set(@PKG2_NAME@_DIALECTS @PKG2_MAVLINK_DIALECTS@)\n "
        }
      ]
