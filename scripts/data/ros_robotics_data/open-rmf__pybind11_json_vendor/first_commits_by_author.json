          "deletions": 0,
          "changes": 1,
          "blob_url": "https://github.com/open-rmf/pybind11_json_vendor/blob/78d4800892c7ae1cc1905a3be6c68ec39fe1808e/package.xml",
          "raw_url": "https://github.com/open-rmf/pybind11_json_vendor/raw/78d4800892c7ae1cc1905a3be6c68ec39fe1808e/package.xml",
          "contents_url": "https://api.github.com/repos/open-rmf/pybind11_json_vendor/contents/package.xml?ref=78d4800892c7ae1cc1905a3be6c68ec39fe1808e",
          "patch": "@@ -9,6 +9,7 @@\n \n   <buildtool_depend>ament_cmake</buildtool_depend>\n \n+  <depend>nlohmann-json-dev</depend>\n   <depend>pybind11_vendor</depend>\n \n   <export>"
